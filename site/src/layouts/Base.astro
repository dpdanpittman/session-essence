---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'session-essence — an AI that remembers who it is',
  description = "session-essence is a small system that gives a Claude Code agent persistent self-knowledge between conversations. Observation-driven, local-only, born from itself.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-ink font-body">
    <main>
      <slot />
    </main>
  </body>
</html>
